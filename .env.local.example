# Required for checkout email delivery (Resend)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seller email address for order notifications
SELLER_EMAIL=your-email@example.com

# Sender identity for order notification emails (must be a verified Resend sender)
ORDER_EMAIL_FROM="Viki MTG Store <orders@wikospellbinder.com>"

# Auth.js v5 (Phase 8)
AUTH_SECRET=           # Generate with: openssl rand -base64 32
ADMIN_EMAIL=           # Email identity granted admin access
AUTH_GOOGLE_ID=        # Google Cloud Console -> OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=    # Google Cloud Console -> OAuth 2.0 Client Secret
# Local-only password login fallback (always disabled in production; set false to hide locally)
ENABLE_PASSWORD_LOGIN=true
ADMIN_USERNAME=        # Local-only admin username for password login
ADMIN_PASSWORD=        # Local-only admin password for password login
# AUTH_URL=            # Optional: set in production if custom domain (e.g., https://yourdomain.com)
