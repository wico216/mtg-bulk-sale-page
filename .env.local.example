# Required for checkout email delivery (Resend)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seller email address for order notifications
SELLER_EMAIL=your-email@example.com

# Auth.js v5 (Phase 8)
AUTH_SECRET=           # Generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=        # Google Cloud Console -> OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=    # Google Cloud Console -> OAuth 2.0 Client Secret
ADMIN_EMAIL=           # Google email that has admin access (D-04)
# AUTH_URL=            # Optional: set in production if custom domain (e.g., https://yourdomain.com)
