# Neon Postgres database connection string (direct, not pooled)
# Get from: https://console.neon.tech -> Project -> Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Required for checkout email delivery (Resend)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seller email address for order notifications
SELLER_EMAIL=your-email@example.com
